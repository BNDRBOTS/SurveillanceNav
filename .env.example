# ── Surveillance Transparency Navigator — environment ──────────────────
# Copy to .env for docker-compose, or export in your shell for local dev.
# In development every value below has a safe default; in production the
# secrets marked REQUIRED must be set or the server refuses to boot.

NODE_ENV=development
HOST=0.0.0.0
PORT=4000
PUBLIC_URL=http://localhost:4000
TRUST_PROXY=false

# Database (PostgreSQL 14+; PostGIS optional — auto-detected with fallback)
DATABASE_URL=postgres://stn:stn_dev_password@localhost:5432/stn
DB_POOL_MAX=10
AUTO_MIGRATE=true

# Cache / queues wake-up (optional — in-memory fallback when absent)
REDIS_URL=redis://localhost:6379

# Secrets — REQUIRED in production (generate: openssl rand -base64 48)
JWT_SECRET=
REFRESH_SECRET=
DOWNLOAD_SECRET=

# Sessions
ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_SEC=2592000
COOKIE_SECURE=false            # true behind HTTPS (required in production)
CORS_ORIGINS=                  # comma-separated; empty = same-origin only

# Object storage: local (dev) or s3 (MinIO/AWS)
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=./var/storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=stn
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# Mail: outbox (dev — writes var/mail/outbox.jsonl) or smtp
MAIL_TRANSPORT=outbox
MAIL_FROM="Lens of Light <no-reply@stn.local>"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Malware scanning: built-in heuristics always run; set for ClamAV daemon
CLAMD_HOST=
CLAMD_PORT=3310

# Rate limiting (runtime-tunable via admin console)
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_MAX=300
RATE_LIMIT_AUTH_MAX=10

# Uploads & retention
UPLOAD_MAX_BYTES=52428800
EXPORT_TTL_HOURS=72
AUDIT_LOG_RETENTION_DAYS=730
DELETED_USER_PURGE_DAYS=30
NOTIFICATION_RETENTION_DAYS=90

# Background jobs
JOBS_ENABLED=true
JOBS_TICK_MS=5000
JOBS_CONCURRENCY=2

# Seeding
SEED_SCALE=demo                # demo (~2k assets) | perf (~100k+)
SEED_DEMO_USERS=true           # never auto-true in production
SEED_DEMO_PASSWORD=LensOfLight-demo-2026
